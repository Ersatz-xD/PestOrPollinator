# --- Datasets and Embeddings ---
# Ignore all raw data folders and large data arrays
dataset/
train/
test/
valid/
*.npy
*.pkl
*.csv

# --- Jupyter & Colab Junk ---
# Ignore notebook auto-saves
.ipynb_checkpoints/

# --- Python Environments & Caches ---
# Ignore cache files that Python generates automatically
__pycache__/
*.pyc
venv/
env/
.env

# --- OS Generated Files ---
# Ignore hidden files created by Mac/Windows
.DS_Store
Thumbs.db